<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Evelien Hesters — Growth marketing for B2B startups & scale-ups</title>
  <meta name="description" content="Growth marketing for B2B startups & scale-ups in motion. Positioning, go-to-market, product marketing, lead gen, sales enablement." />

  <!-- Optional: swap to your own fonts later -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg: #fbf7f1;
      --ink: #141414;
      --muted: rgba(20,20,20,.72);
      --soft: rgba(20,20,20,.10);
      --accent: #ff5a3c; /* warm coral */
      --card: rgba(255,255,255,.55);
      --radius: 18px;
      --max: 1120px;
    }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      margin:0;
      background: var(--bg);
      color: var(--ink);
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      letter-spacing: -0.01em;
    }

    a{ color:inherit; text-decoration:none; }
    a:hover{ text-decoration:underline; text-decoration-thickness: 2px; text-underline-offset: 3px; }

    .wrap{ max-width: var(--max); margin:0 auto; padding: 36px 22px 88px; }

    /* Top bar */
    .top{
      display:flex; align-items:center; justify-content:space-between;
      gap:16px;
      position: sticky; top:0;
      padding: 16px 0;
      background: linear-gradient(to bottom, var(--bg) 75%, rgba(251,247,241,0));
      backdrop-filter: blur(2px);
      z-index: 10;
    }
    .brand{
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      font-size: 12px;
    }
    .nav{
      display:flex; gap:14px; flex-wrap:wrap;
      font-size: 13px;
      color: var(--muted);
    }
    .nav a{ padding: 8px 10px; border-radius: 999px; }
    .nav a:hover{ background: var(--card); text-decoration:none; color: var(--ink); }

    /* Hero */
    .hero{
      display:grid;
      grid-template-columns: 1.05fr .95fr;
      gap: 30px;
      align-items: center;
      padding: 48px 0 22px;
    }
    .kicker{
      font-size: 12px;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 18px;
    }
    h1{
      margin: 0 0 18px;
      font-family: Fraunces, ui-serif, Georgia, serif;
      font-weight: 600;
      font-size: clamp(40px, 4.6vw, 72px);
      line-height: 1.02;
      letter-spacing: -0.03em;
    }
    .hero p{
      margin: 0 0 18px;
      font-size: 16px;
      line-height: 1.65;
      color: var(--muted);
      max-width: 60ch;
    }
    .hero strong{ color: var(--ink); font-weight: 500; }
    .ctaRow{ display:flex; gap:12px; flex-wrap:wrap; margin-top: 22px; }
    .btn{
      display:inline-flex; align-items:center; justify-content:center;
      padding: 12px 16px;
      border-radius: 999px;
      border: 1px solid var(--soft);
      background: var(--card);
      font-size: 14px;
      font-weight: 500;
      gap: 10px;
      transition: transform .08s ease, background .12s ease;
    }
    .btn:hover{ background: rgba(255,255,255,.8); transform: translateY(-1px); text-decoration:none; }
    .btn.primary{
      background: var(--ink);
      border-color: var(--ink);
      color: var(--bg);
    }
    .btn.primary:hover{ background: rgba(20,20,20,.92); }
    .dot{
      width:8px; height:8px; border-radius: 50%;
      background: var(--accent);
      display:inline-block;
    }

    /* Hero visual */
    .portrait{
      border-radius: var(--radius);
      overflow:hidden;
      border: 1px solid var(--soft);
      background: rgba(255,255,255,.35);
      box-shadow: 0 12px 35px rgba(20,20,20,.08);
      aspect-ratio: 4/5;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .portrait img{
      width:100%; height:100%;
      object-fit: cover;
      display:block;
    }
    .portrait .ph{
      padding: 26px;
      text-align:left;
      width:100%;
    }
    .phTitle{
      font-family: Fraunces, ui-serif, Georgia, serif;
      font-weight: 600;
      font-size: 20px;
      margin: 0 0 6px;
    }
    .phText{
      margin:0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
    }

    /* Section layout */
    section{ padding: 62px 0; border-top: 1px solid var(--soft); }
    .sectionHead{
      display:flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 18px;
      margin-bottom: 26px;
    }
    .label{
      font-size: 12px;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--muted);
      min-width: 140px;
    }
    .title{
      font-family: Fraunces, ui-serif, Georgia, serif;
      font-weight: 600;
      font-size: clamp(28px, 3vw, 40px);
      line-height: 1.06;
      margin:0;
    }
    .grid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      align-items: start;
    }

    .card{
      border: 1px solid var(--soft);
      background: var(--card);
      border-radius: var(--radius);
      padding: 18px 18px 16px;
    }
    .card h3{
      margin: 0 0 8px;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: .14em;
      color: var(--muted);
      font-weight: 500;
    }
    .card p{
      margin:0;
      line-height: 1.65;
      color: var(--muted);
      font-size: 15px;
    }
    .list{
      margin: 0;
      padding: 0;
      list-style:none;
      display:flex;
      flex-direction:column;
      gap:10px;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.55;
    }
    .list li{
      padding-left: 18px;
      position:relative;
    }
    .list li::before{
      content:"";
      width:8px; height:8px;
      border-radius: 50%;
      background: var(--accent);
      position:absolute;
      left:0;
      top:.6em;
    }

    /* “Places I’ve poured at” */
    .logos{
      display:flex;
      flex-wrap:wrap;
      gap: 10px;
      margin-top: 12px;
    }
    .pill{
      border: 1px solid var(--soft);
      background: rgba(255,255,255,.45);
      padding: 10px 12px;
      border-radius: 999px;
      font-size: 13px;
      color: rgba(20,20,20,.78);
    }

    /* Contact */
    .contactCard{
      display:grid;
      grid-template-columns: 1.2fr .8fr;
      gap: 18px;
      align-items:center;
    }
    .contactCard .card{ padding: 22px; }
    .contactCard p{ font-size: 15px; }
    .small{
      font-size: 13px;
      color: var(--muted);
      line-height: 1.55;
    }
    footer{
      padding-top: 36px;
      color: var(--muted);
      font-size: 12px;
    }

    /* Responsive */
    @media (max-width: 900px){
      .hero{ grid-template-columns: 1fr; padding-top: 22px; }
      .portrait{ aspect-ratio: 16/10; }
      .grid{ grid-template-columns: 1fr; }
      .contactCard{ grid-template-columns: 1fr; }
      .sectionHead{ flex-direction:column; align-items:flex-start; }
      .label{ min-width: auto; }
    }
  </style>
</head>

<body>
  <div class="wrap">
    <div class="top">
      <div class="brand">Evelien Hesters</div>
      <nav class="nav" aria-label="Primary">
        <a href="#story">Story</a>
        <a href="#what">What I do</a>
        <a href="#work">How we work</a>
        <a href="#experience">Experience</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>

    <header class="hero">
      <div>
        <div class="kicker">B2B • startups & scale-ups • go-to-market</div>

        <h1>
          Building great products is one thing.<br/>
          Bringing them to market is another.
        </h1>

        <p>
          That’s where I come in. I work with <strong>B2B start-ups and scale-ups</strong> that build strong products,
          but want sharper positioning and a go-to-market that <strong>clicks</strong>.
        </p>

        <p>
          With 10+ years across agencies, SaaS and product environments, I help teams understand their audience better
          and translate what they’re building into something the market understands.
        </p>

        <div class="ctaRow">
          <a class="btn primary" href="#contact"><span class="dot"></span> Let’s talk</a>
          <a class="btn" href="mailto:hello@evelienhesters.com">Email me</a>
          <a class="btn" href="https://www.linkedin.com/" target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>

      <div class="portrait" aria-label="Portrait">
        <!-- Replace the placeholder with your own image file path -->
        <!-- <img src="images/evelien.jpg" alt="Evelien Hesters portrait" /> -->
        <div class="ph">
          <div class="phTitle">Photo goes here</div>
          <p class="phText">
            Replace this block with a portrait image when ready.<br/>
            The layout is designed to still look good with minimal visuals.
          </p>
        </div>
      </div>
    </header>

    <section id="story">
      <div class="sectionHead">
        <div class="label">Story</div>
        <h2 class="title">Less noise. More landing.</h2>
      </div>

      <div class="grid">
        <div class="card">
          <h3>The context</h3>
          <p>
            Everyone can build products now. AI made “shipping” faster. The market didn’t get quieter.
            So the advantage isn’t building more. It’s <strong>bringing the right thing to the right people</strong>.
          </p>
        </div>
        <div class="card">
          <h3>What I’m here for</h3>
          <p>
            I help teams find the sharpest version of their positioning and turn it into a go-to-market that’s simple,
            coherent, and actually usable by marketing and sales.
          </p>
        </div>
      </div>
    </section>

    <section id="what">
      <div class="sectionHead">
        <div class="label">What I do</div>
        <h2 class="title">Specialty servings 🍸</h2>
      </div>

      <div class="grid">
        <div class="card">
          <h3>Where I’m most useful</h3>
          <ul class="list">
            <li>Product marketing that clarifies the “why you”</li>
            <li>Positioning and messaging that sales can repeat</li>
            <li>Go-to-market planning that doesn’t live in a deck</li>
            <li>Growth marketing and lead generation with focus</li>
            <li>Sales enablement that makes the handoff smoother</li>
          </ul>
        </div>

        <div class="card">
          <h3>What you can expect</h3>
          <p>
            A <strong>perfect blend</strong> of strategy and execution. I’ll ask the uncomfortable questions, simplify
            the story, and help the team move. No theatre. No buzzword fog. Just work that lands.
          </p>
        </div>
      </div>
    </section>

    <section id="work">
      <div class="sectionHead">
        <div class="label">How we work</div>
        <h2 class="title">Shaken and stirred, depending on the stage.</h2>
      </div>

      <div class="grid">
        <div class="card">
          <h3>Formats</h3>
          <ul class="list">
            <li>Hands-on growth lead support (part-time)</li>
            <li>Product marketing / GTM partner</li>
            <li>Workshops and facilitation (positioning, GTM, messaging)</li>
            <li>Coaching for marketers (and the occasional founder)</li>
          </ul>
        </div>

        <div class="card">
          <h3>Typical starting point</h3>
          <p>
            A quick reset: what are we selling, to whom, why should they care, and what’s the simplest path to
            consistent demand? From there, we build a plan that the team can actually run with.
          </p>
        </div>
      </div>
    </section>

    <section id="experience">
      <div class="sectionHead">
        <div class="label">Experience</div>
        <h2 class="title">Previously poured at</h2>
      </div>

      <div class="card">
        <p class="small">
          A few places I’ve worked with (add/remove as you like):
        </p>
        <div class="logos" aria-label="Companies">
          <span class="pill">Alan</span>
          <span class="pill">T-Shaped Academy</span>
          <span class="pill">Optioryx</span>
          <span class="pill">Leap Forward</span>
          <span class="pill">Springbok</span>
          <span class="pill">The Reference</span>
          <span class="pill">Telenet</span>
        </div>
      </div>
    </section>

    <section id="contact">
      <div class="sectionHead">
        <div class="label">Contact</div>
        <h2 class="title">Want to talk it through?</h2>
      </div>

      <div class="contactCard">
        <div class="card">
          <p style="margin:0 0 10px;">
            If you’re building in B2B and want your go-to-market to feel clearer, sharper, and easier to execute,
            send me a note.
          </p>
          <div class="ctaRow" style="margin-top:14px;">
            <a class="btn primary" href="mailto:hello@evelienhesters.com"><span class="dot"></span> Email me</a>
            <a class="btn" href="https://www.linkedin.com/" target="_blank" rel="noreferrer">Message on LinkedIn</a>
          </div>
          <p class="small" style="margin-top:12px;">
            Prefer a quick call? Add a scheduling link here (Calendly, etc.).
          </p>
        </div>

        <div class="card">
          <h3>Quick details</h3>
          <p class="small" style="margin:0;">
            Location: Belgium (remote-friendly)<br/>
            Availability: part-time / fractional / project-based<br/>
            Email: hello@evelienhesters.com
          </p>
        </div>
      </div>

      <footer>
        © <span id="y"></span> Evelien Hesters • Built as a simple one-pager.
      </footer>
    </section>
  </div>

  <script>
    document.getElementById("y").textContent = new Date().getFullYear();
  </script>
</body>
</html>
